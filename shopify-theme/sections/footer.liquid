<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">
      <div class="footer-col">
        <div class="footer-col__title">{{ shop.name }}</div>
        {%- if section.settings.description != blank -%}
          <p style="font-size:0.875rem;line-height:1.6;">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- for i in (1..3) -%}
        {%- assign menu_setting = 'menu_' | append: i -%}
        {%- assign title_setting = 'menu_title_' | append: i -%}
        {%- if section.settings[menu_setting] != blank -%}
          <div class="footer-col">
            <div class="footer-col__title">{{ section.settings[title_setting] }}</div>
            <ul class="footer-col__links">
              {%- for link in linklists[section.settings[menu_setting]].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Visos teisės saugomos.</span>
      {%- if shop.enabled_payment_types != empty -%}
        <div class="payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Poraštė",
  "settings": [
    { "type": "textarea", "id": "description", "label": "Aprašymas" },
    { "type": "text", "id": "menu_title_1", "label": "1 meniu pavadinimas", "default": "Parduotuvė" },
    { "type": "link_list", "id": "menu_1", "label": "1 meniu", "default": "footer" },
    { "type": "text", "id": "menu_title_2", "label": "2 meniu pavadinimas", "default": "Informacija" },
    { "type": "link_list", "id": "menu_2", "label": "2 meniu" },
    { "type": "text", "id": "menu_title_3", "label": "3 meniu pavadinimas", "default": "Kontaktai" },
    { "type": "link_list", "id": "menu_3", "label": "3 meniu" }
  ]
}
{% endschema %}
